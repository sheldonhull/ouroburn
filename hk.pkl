amends "package://github.com/jdx/hk/releases/download/v1.45.0/hk@1.45.0#/Config.pkl"
import "package://github.com/jdx/hk/releases/download/v1.45.0/hk@1.45.0#/Builtins.pkl"

local swiftformat = new Step {
    glob = List("*.swift")
    check = "swiftformat --lint {{files}}"
    fix = "swiftformat {{files}}"
}

local swiftlint = new Step {
    glob = List("*.swift")
    check = "swiftlint lint --quiet --strict {{files}}"
}

// swiftlint depends on the full Xcode SourceKit framework. Machines that only have
// Command Line Tools installed will fail with `Loading sourcekitdInProc.framework ... failed`,
// so it's kept out of pre-commit and lives in the manual `lint` hook instead.
local commitLinters = new Mapping<String, Step> {
    ["swiftformat"] = swiftformat
    ["trailing-whitespace"] = Builtins.trailing_whitespace
}

local fullLinters = new Mapping<String, Step> {
    ["swiftformat"] = swiftformat
    ["swiftlint"] = swiftlint
    ["trailing-whitespace"] = Builtins.trailing_whitespace
}

hooks {
    ["pre-commit"] {
        fix = true
        stash = "git"
        steps = commitLinters
    }
    ["fix"] {
        fix = true
        steps = commitLinters
    }
    ["check"] {
        steps = commitLinters
    }
    ["lint"] {
        steps = fullLinters
    }
    ["pre-push"] {
        steps {
            ["build"] {
                check = "swift build -c release"
            }
        }
    }
}
